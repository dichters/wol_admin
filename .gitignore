#
# ========== Binaries ==========
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# ========== Test ==========
*.test
*.out
coverage.*
*.coverprofile
profile.cov

# ========== Dependencies ==========
vendor/

# ========== Workspace ==========
go.work.sum

# ========== Logs ==========
log/*.log
*.log

# ========== Environment ==========
.env
.env.local
.env.*.local

# ========== Editor/IDE ==========
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ========== Temporary files ==========
tmp/
temp/
*.tmp
*.bak
